{
    "actorSpecification": 1,
    "description": "Dataset schema for Kickstarter Pre-Launch Follower Tracker output",
    "fields": {
        "url": {
            "type": "string",
            "title": "Project URL",
            "description": "The Kickstarter project URL that was scraped"
        },
        "projectName": {
            "type": "string",
            "title": "Project Name",
            "description": "Name of the Kickstarter project",
            "nullable": true
        },
        "creatorName": {
            "type": "string",
            "title": "Creator Name",
            "description": "Name of the project creator",
            "nullable": true
        },
        "category": {
            "type": "string",
            "title": "Category",
            "description": "Project category",
            "nullable": true
        },
        "subcategory": {
            "type": "string",
            "title": "Subcategory",
            "description": "Project subcategory",
            "nullable": true
        },
        "projectDescription": {
            "type": "string",
            "title": "Description",
            "description": "Short description of the project",
            "nullable": true
        },
        "followerCount": {
            "type": "integer",
            "title": "Follower Count",
            "description": "Number of followers (Notify Me count) for pre-launch projects",
            "nullable": true
        },
        "location": {
            "type": "string",
            "title": "Location",
            "description": "Project or creator location",
            "nullable": true
        },
        "backerCount": {
            "type": "integer",
            "title": "Backer Count",
            "description": "Number of backers for live projects",
            "nullable": true
        },
        "scrapedAt": {
            "type": "string",
            "title": "Scraped At",
            "description": "ISO timestamp of when the data was scraped"
        }
    },
    "views": {
        "overview": {
            "title": "Overview",
            "transformation": {
                "fields": [
                    "url",
                    "projectName",
                    "creatorName",
                    "category",
                    "subcategory",
                    "projectDescription",
                    "followerCount",
                    "location",
                    "backerCount",
                    "scrapedAt"
                ]
            },
            "display": {
                "component": "table",
                "properties": {
                    "url": {
                        "label": "Project URL",
                        "format": "text"
                    },
                    "projectName": {
                        "label": "Project Name",
                        "format": "text"
                    },
                    "creatorName": {
                        "label": "Creator Name",
                        "format": "text"
                    },
                    "category": {
                        "label": "Category",
                        "format": "text"
                    },
                    "subcategory": {
                        "label": "Subcategory",
                        "format": "text"
                    },
                    "projectDescription": {
                        "label": "Description",
                        "format": "text"
                    },
                    "followerCount": {
                        "label": "Follower Count",
                        "format": "number"
                    },
                    "location": {
                        "label": "Location",
                        "format": "text"
                    },
                    "backerCount": {
                        "label": "Backer Count",
                        "format": "number"
                    },
                    "scrapedAt": {
                        "label": "Scraped At",
                        "format": "text"
                    }
                }
            }
        }
    }
}
